{
  "name": "vtgl",
  "version": "0.0.0",
  "description": "Standalone WebGL2 glyph-atlas terminal renderer driven by a pluggable read-only VT source.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "docs",
    "THIRD-PARTY.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:vendor": "node scripts/build-vendor.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --test --expose-gc --experimental-strip-types \"test/**/*.test.ts\"",
    "test:browser": "node scripts/build-harness.mjs && playwright test webgl2.spec.ts",
    "bench": "node --experimental-strip-types bench/render-bench.ts",
    "bench:browser": "node scripts/build-harness.mjs && playwright test bench.spec.ts",
    "check": "npm run typecheck && npm run test && npm run test:browser && npm run build"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
